[user]
	name = Bruno Y. Baldochi
[alias]
	dt = difftool
	mt = mergetool
	st = status --short --branch
[color]
	ui = true
[commit]
	verbose = true
[core]
	editor = vim
[diff]
	tool = vimdiff2
[difftool]
	prompt = false
[fetch]
	prune = true
[merge]
	tool = vimdiff2
[mergetool]
	prompt = false
	keepbackup = false
[pull]
	rebase = true
[push]
	default = simple
[rebase]
	autosquash = true
[include]
	path = ~/.gitconfig_local
